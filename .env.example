# .env.example
# このファイルをコピーして .env を作成し、環境に合わせて編集してください。
# .env はリポジトリに含めないでください（.gitignore 対象）。

# ── 開発環境（SQLite） ──────────────────────────────────────
# DATABASE_URL=sqlite:///./bbs.db

# ── ローカル PostgreSQL（Docker Compose） ────────────────────
# docker-compose.yml のデフォルト値に合わせた接続URL
# DATABASE_URL=postgresql://bbs_user:bbs_password@localhost:5432/bbs

# docker-compose.yml の環境変数をカスタマイズする場合はこちらも合わせて変更
# POSTGRES_DB=bbs
# POSTGRES_USER=bbs_user
# POSTGRES_PASSWORD=bbs_password

# ── 本番環境（PostgreSQL） ───────────────────────────────────
# DATABASE_URL=postgresql://user:password@your-host:5432/bbs
